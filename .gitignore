# Virtual environment
.venv/
venv/
env/

# Python bytecode
__pycache__/
*.pyc
*.pyo
*.pyd

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data — not for version control (regenerate via src/data_ingestion.py or notebooks)
data/*.csv
data/*.parquet
data/raw/*.xls
data/raw/*.xlsx
data/raw/*.csv
data/raw/*.parquet
data/processed/*.parquet
data/processed/*.csv

# Model artifacts (track via MLflow instead)
models/*.pkl
models/*.joblib
models/*.bin

# Logs & databases
*.log
*.db
*.sqlite

# Environment variables (secrets)
.env
.env.*

# OS artifacts
.DS_Store
Thumbs.db

# IDE
.vscode/settings.json
.idea/

# Reports (generated output — regenerate via notebooks/09_evidently_monitoring.ipynb)
reports/*.html
reports/figures/*.png
reports/figures/*.html

# MLflow
mlruns/
mlartifacts/
