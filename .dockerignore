# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
*.so

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Jupyter / notebooks ────────────────────────────────────────────────────────
notebooks/
*.ipynb
.ipynb_checkpoints/

# ── Data files (re-downloaded on first boot via --download flag) ───────────────
data/

# ── Model artifacts (trained on first boot by entrypoint.sh) ──────────────────
models/

# ── Reports & figures (generated by notebooks, not needed at runtime) ──────────
reports/

# ── Documentation ─────────────────────────────────────────────────────────────
docs/
*.md
!README.md

# ── Development & testing tools ───────────────────────────────────────────────
tests/
requirements-dev.txt
.pytest_cache/
pytest.ini
setup.cfg
.coverage
htmlcov/

# ── Git ───────────────────────────────────────────────────────────────────────
.git/
.gitignore

# ── IDE & OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.DS_Store
Thumbs.db

# ── Environment & secrets ─────────────────────────────────────────────────────
.env
.env.*
*.env
secrets/

# ── Docker artifacts (avoid recursive COPY confusion) ─────────────────────────
Dockerfile
.dockerignore
